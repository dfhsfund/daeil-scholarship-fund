# Google Apps Script 웹앱 URL (배포 → 웹 앱 URL)
VITE_APPS_SCRIPT_URL=

# 슬랙 Incoming Webhook URL — Apps Script를 거치지 않고 사이트가 신청 접수 직후 직접 호출합니다.
# 비워두면 슬랙 알림만 생략되고 구글 시트 저장에는 영향 없습니다.
VITE_SLACK_WEBHOOK_URL=

# 관리용 구글 시트 URL
VITE_SHEET_URL=https://docs.google.com/spreadsheets/d/1AH6vKvz22jZlaV2s1WAogUJ5QyPiEZq3gOsWOvPv0l0/edit

# 관리자 조회 비밀번호는 Apps Script 스크립트 속성 ADMIN_TOKEN 에 설정합니다.
# /admin 접속 시 동일 값을 입력해야 계좌 포함 신청 내역을 볼 수 있습니다.

# 사이트 공개 URL (OG 메타용)
VITE_SITE_URL=https://fund.dflhs.or.kr

# 커스텀 도메인 사용 시 /
VITE_BASE_PATH=/
